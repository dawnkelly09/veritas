# Veritas Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git (it's in .gitignore)

# =============================================================================
# LIT PROTOCOL (Vincent) - Key Management & Encryption
# =============================================================================
# Lit Protocol uses Naga network (no API key needed for Naga Dev)
# Naga Dev is free for development; Naga Test/Mainnet require payment
# 
# Network options: nagaDev (free), nagaTest (test tokens), naga (mainnet)
LIT_NETWORK=nagaDev

# Wallet credentials for Lit operations
# Create a MetaMask wallet or use existing EOA
WALLET_ADDRESS=your_wallet_address_here
WALLET_PRIVATE_KEY=your_wallet_private_key_here

# Lit Actions for policy enforcement (optional for v1)
# LIT_ACTION_IPFS_CID=your_lit_action_cid

# =============================================================================
# STORACHA - UCAN-based Storage
# =============================================================================
# 1. Create account at: https://console.storacha.network
# 2. Verify email and select plan (Free tier available)
# 3. Create a Space (generates a DID)
# 4. Generate UCAN delegation for Veritas agent
#    - Use CLI: npm install -g @storacha/cli
#    - storacha login your-email@example.com
#    - storacha space create veritas-constitution
#    - storacha delegation create <agent-did> --output ./veritas-agent.ucan
#
# Note: UCAN delegation must be base64-encoded for env variable
STORACHA_EMAIL=your-email@example.com
STORACHA_SPACE_DID=did:key:your_space_did_here
STORACHA_DELEGATION_PROOF=base64_encoded_ucan_delegation_here

# =============================================================================
# FILECOIN - On-chain Anchoring
# =============================================================================
# Filecoin wallet for anchoring constitution CIDs on-chain
# Same wallet as Lit Protocol can be used (MetaMask works with Filecoin EVM)
FILECOIN_WALLET_ADDRESS=your_filecoin_wallet_address

# RPC endpoint - Glif provides public endpoints
# Mainnet: https://api.node.glif.io/rpc/v1
# Calibration testnet: https://api.calibration.node.glif.io/rpc/v1
FILECOIN_RPC_URL=https://api.node.glif.io/rpc/v1

# Contract address for CID anchoring (deployed by us or shared)
# FILECOIN_ANCHOR_CONTRACT=0x...

# =============================================================================
# VERITAS AGENT CONFIGURATION
# =============================================================================
# Agent identity
AGENT_NAME=Trinity
AGENT_ID=trinity-veritas-001
HUMAN_OWNER=dawnkelly09@gmail.com

# Bootstrap configuration
# Workspace is primary; Obsidian is interface + backup, not sync target
BOOTSTRAP_PRIMARY_LOCATIONS=/Users/trinity/.openclaw/workspace/memory/
BOOTSTRAP_FALLBACK_LOCATIONS=/Users/trinity/Documents/Trinity-Mind/OpenClaw\ Backup/

# Constitution storage
CONSTITUTION_FILENAME=constitution.md
ENCRYPTED_CONSTITUTION_CID=placeholder_until_first_anchor

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================
# FastAPI/Uvicorn settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=info

# =============================================================================
# GUARDIAN & VALIDATOR SETTINGS
# =============================================================================
# Guardian injection detection thresholds
GUARDIAN_BLOCK_THRESHOLD=0.8
GUARDIAN_ALERT_THRESHOLD=0.5

# Validator response on constitution violation
# Options: log, alert, block
VALIDATOR_VIOLATION_ACTION=alert

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================
# Set to true to use mock data instead of real integrations
USE_MOCK_DATA=false

# Enable detailed logging for sponsor integrations
DEBUG_LIT=false
DEBUG_STORACHA=false
DEBUG_FILECOIN=false

# =============================================================================
# FUTURE ENHANCEMENTS (Phase 2+)
# =============================================================================
# Local IPFS node for decentralized agent communication
# Benefits: CID generation without gateways, mesh network capability,
# resilience if internet infrastructure is compromised
# 
# To enable:
# 1. Install IPFS (kubo): https://docs.ipfs.io/install/
# 2. Run: ipfs init && ipfs daemon
# 3. Set LOCAL_IPFS_ENABLED=true
# 4. Configure LOCAL_IPFS_API_URL (default: http://localhost:5001)
#
# LOCAL_IPFS_ENABLED=false
# LOCAL_IPFS_API_URL=http://localhost:5001
# LOCAL_IPFS_GATEWAY_URL=http://localhost:8080

# =============================================================================
# NOTES
# =============================================================================
# - All sponsor credentials should be generated on your local machine
# - Never share private keys or UCAN tokens
# - Keep this .env file backed up securely
# - For team development, each developer needs their own .env
# - Lit Protocol: No API key needed for Naga Dev (free tier)
# - Storacha: Requires email signup + UCAN delegation creation
# - Filecoin: Use same wallet as Lit, just need small amount of FIL for gas
