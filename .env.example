# Veritas Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git (it's in .gitignore)

# =============================================================================
# LIT PROTOCOL (Vincent) - Key Management & Encryption
# =============================================================================
# Get your API key from: https://developer.litprotocol.com/
LIT_PROTOCOL_API_KEY=your_lit_api_key_here

# Vincent Wallet credentials (non-custodial key management)
VINCENT_WALLET_ADDRESS=your_vincent_wallet_address
VINCENT_WALLET_PRIVATE_KEY=your_vincent_private_key

# Lit Actions for policy enforcement (optional for v1)
# LIT_ACTION_IPFS_CID=your_lit_action_cid

# =============================================================================
# STORACHA - UCAN-based Storage
# =============================================================================
# Create account at: https://storacha.network/
# Generate UCAN delegation token from their web UI
STORACHA_UCAN_TOKEN=your_storacha_ucan_jwt_token_here

# Space DID for your Veritas storage space
STORACHA_SPACE_DID=did:key:your_space_did_here

# =============================================================================
# FILECOIN - On-chain Anchoring (Calibration Testnet)
# =============================================================================
# Create wallet at: https://calibration.filfox.info/
# Get test FIL from: https://faucet.calibration.fildev.network/
FILECOIN_CALIBRATION_WALLET_ADDRESS=your_filecoin_wallet_address
FILECOIN_CALIBRATION_PRIVATE_KEY=your_filecoin_private_key

# Filecoin API endpoint (use Glif or Lotus node)
FILECOIN_RPC_URL=https://api.calibration.node.glif.io/rpc/v1

# Contract address for CID anchoring (deployed by us or shared)
# FILECOIN_ANCHOR_CONTRACT=0x...

# =============================================================================
# VERITAS AGENT CONFIGURATION
# =============================================================================
# Agent identity
AGENT_NAME=Trinity
AGENT_ID=trinity-veritas-001
HUMAN_OWNER=dawnkelly09@gmail.com

# Bootstrap configuration
BOOTSTRAP_PRIMARY_LOCATIONS=/Users/trinity/Documents/Trinity-Mind/01-Daily/,/Users/trinity/.openclaw/workspace/memory/
BOOTSTRAP_FALLBACK_LOCATIONS=/Users/trinity/Documents/Trinity-Mind/OpenClaw Backup/,/Users/trinity/Desktop/

# Constitution storage
CONSTITUTION_FILENAME=constitution.md
ENCRYPTED_CONSTITUTION_CID=placeholder_until_first_anchor

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================
# FastAPI/Uvicorn settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=info

# =============================================================================
# GUARDIAN & VALIDATOR SETTINGS
# =============================================================================
# Guardian injection detection thresholds
GUARDIAN_BLOCK_THRESHOLD=0.8
GUARDIAN_ALERT_THRESHOLD=0.5

# Validator response on constitution violation
# Options: log, alert, block
VALIDATOR_VIOLATION_ACTION=alert

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================
# Set to true to use mock data instead of real integrations
USE_MOCK_DATA=false

# Enable detailed logging for sponsor integrations
DEBUG_LIT=false
DEBUG_STORACHA=false
DEBUG_FILECOIN=false

# =============================================================================
# NOTES
# =============================================================================
# - All sponsor credentials should be generated on your local machine
# - Never share private keys or UCAN tokens
# - Keep this .env file backed up securely
# - For team development, each developer needs their own .env
